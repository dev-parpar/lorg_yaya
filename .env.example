# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Use Supabase, Neon, or local Docker.
# Example (Supabase): postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/lorg_yaya"

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ── Supabase Service Role (NEVER expose to client) ───────────────────────────
# Required for server-side admin operations (e.g. deleting auth users).
# Found in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ──────────────────────────────────────────────────────────────────────
# Set to "production" in prod deployments
NODE_ENV="development"

# ── AI / Chat ────────────────────────────────────────────────────────────────
# Supported providers: "anthropic" | "openai"
AI_PROVIDER="anthropic"
# Swap this value to change model — no code changes required
AI_MODEL="claude-3-5-sonnet-20241022"
AI_MAX_TOKENS="1024"
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=""
