generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Stores public profile data for each Supabase auth user.
// userId maps 1:1 to the Supabase auth.users UUID.
model Profile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique @map("user_id")
  username  String   @unique @db.VarChar(30)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([username])
  @@map("profiles")
}

enum LocationType {
  HOME
  OFFICE
}

model Location {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @map("user_id")
  name      String       @db.VarChar(255)
  type      LocationType @default(HOME)
  address   String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  cabinets Cabinet[]

  @@index([userId])
  @@index([deletedAt])
  @@map("locations")
}

model Cabinet {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId  String    @map("location_id") @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  location Location @relation(fields: [locationId], references: [id])
  shelves  Shelf[]
  items    Item[]

  @@index([locationId])
  @@index([deletedAt])
  @@map("cabinets")
}

model Shelf {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId String    @map("cabinet_id") @db.Uuid
  name      String    @db.VarChar(255)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  items   Item[]

  @@index([cabinetId])
  @@index([deletedAt])
  @@map("shelves")
}

model Item {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId    String    @map("cabinet_id") @db.Uuid
  shelfId      String?   @map("shelf_id") @db.Uuid
  name         String    @db.VarChar(255)
  description  String?   @db.Text
  quantity     Int       @default(1)
  imageUrl     String?   @map("image_url") @db.Text
  tags         String[]  @default([])
  // searchVector is maintained by a DB trigger — see migrations
  searchVector Unsupported("tsvector")?  @map("search_vector")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  @@index([cabinetId])
  @@index([shelfId])
  @@index([deletedAt])
  @@map("items")
}
