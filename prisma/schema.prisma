generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProfileStatus {
  ACTIVE
  DELETED
}

// Stores public profile data for each Supabase auth user.
// userId maps 1:1 to the Supabase auth.users UUID.
//
// Lifecycle:
//   ACTIVE  — normal account, can log in and use the app
//   DELETED — account was deleted; Supabase auth user has been hard-deleted
//             so the email is free for re-registration. This row is kept as
//             an audit record only. userId is a dead reference.
model Profile {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String        @unique @map("user_id")
  username  String        @unique @db.VarChar(30)
  status    ProfileStatus @default(ACTIVE) @map("status")
  deletedAt DateTime?     @map("deleted_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([username, status])
  @@map("profiles")
}

enum LocationType {
  HOME
  OFFICE
}

// Role a member holds on a shared location.
// Only EDITOR exists now; VIEWER can be added in a future iteration.
enum MemberRole {
  EDITOR
}

// Lifecycle of an invite from owner to another user.
enum InviteStatus {
  PENDING   // invite sent, awaiting response
  ACCEPTED  // member has access
  DECLINED  // invitee declined — no access granted
  REVOKED   // owner removed the member
}

model Location {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @map("user_id")
  name      String       @db.VarChar(255)
  type      LocationType @default(HOME)
  address   String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  cabinets Cabinet[]
  members  LocationMember[]

  @@index([userId])
  @@index([deletedAt])
  @@map("locations")
}

// Join table granting a non-owner user access to a Location.
// The owner is always Location.userId — no row needed for them.
model LocationMember {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId  String       @map("location_id") @db.Uuid
  userId      String       @map("user_id")    // invited user's Supabase userId
  invitedBy   String       @map("invited_by") // owner's userId at time of invite
  role        MemberRole   @default(EDITOR)
  status      InviteStatus @default(PENDING)
  invitedAt   DateTime     @default(now()) @map("invited_at")
  respondedAt DateTime?    @map("responded_at")

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, userId])
  @@index([userId, status])
  @@index([locationId, status])
  @@map("location_members")
}

model Cabinet {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  locationId  String    @map("location_id") @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  location Location @relation(fields: [locationId], references: [id])
  shelves  Shelf[]
  items    Item[]

  @@index([locationId])
  @@index([deletedAt])
  @@map("cabinets")
}

model Shelf {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId String    @map("cabinet_id") @db.Uuid
  name      String    @db.VarChar(255)
  position  Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  items   Item[]

  @@index([cabinetId])
  @@index([deletedAt])
  @@map("shelves")
}

model Item {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cabinetId    String    @map("cabinet_id") @db.Uuid
  shelfId      String?   @map("shelf_id") @db.Uuid
  name         String    @db.VarChar(255)
  description  String?   @db.Text
  quantity     Int       @default(1)
  imageUrl     String?   @map("image_url") @db.Text
  tags         String[]  @default([])
  // searchVector is maintained by a DB trigger — see migrations
  searchVector Unsupported("tsvector")?  @map("search_vector")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  cabinet Cabinet @relation(fields: [cabinetId], references: [id])
  shelf   Shelf?  @relation(fields: [shelfId], references: [id])

  @@index([cabinetId])
  @@index([shelfId])
  @@index([deletedAt])
  @@map("items")
}
